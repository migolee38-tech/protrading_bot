# 複製為 .env 後填入（勿 commit .env）

# 站台登入（設了 APP_LOGIN_PASSWORD 即啟用；Zeabur 請用 Variables 同名字段）
APP_LOGIN_USER=admin
APP_LOGIN_PASSWORD=請改成強密碼

# 永續行情（Zeabur 建議）
# BINANCE_STRICT_FUTURES=1
# BINANCE_ALLOW_SPOT_WS_FALLBACK=0

# ── 下單模式與 API 金鑰 ─────────────────────────────────────────
# paper   → 本地模擬，不需金鑰
# testnet → 幣安永續模擬倉（https://testnet.binancefuture.com）
# live    → 主網實盤（https://www.binance.com）

# Testnet 專用（建議與主網分開命名，避免搞混）
BINANCE_TESTNET_API_KEY=your_testnet_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_secret_here

# 主網實盤專用
BINANCE_API_KEY=your_mainnet_key_here
BINANCE_API_SECRET=your_mainnet_secret_here

# 啟動 24/7 多策略自動交易：
#   ./start_live_trader.sh --verify
#   ./start_live_trader.sh --paper --bg
#   ./start_live_trader.sh --bg              # testnet
#   ./start_live_trader.sh --live --bg       # 主網（需確認）

# 可選：Telegram 訊號通知
# TG_TOKEN=
# TG_CHAT_ID=

# 可選：自動交易資金參數
# LIVE_TOTAL_CAPITAL=1000
# LIVE_POSITION_PCT=1
