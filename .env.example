# 複製為 .env 後填入（勿 commit .env）

# 站台登入（設了 APP_LOGIN_PASSWORD 即啟用；Zeabur 請用 Variables 同名字段）
APP_LOGIN_USER=admin
APP_LOGIN_PASSWORD=請改成強密碼

# 永續行情（Zeabur 建議）
# BINANCE_STRICT_FUTURES=1
# BINANCE_ALLOW_SPOT_WS_FALLBACK=0

# ── 多帳戶設定 ─────────────────────────────────────────────────
TRADING_ACCOUNTS=account1,account2
ACCOUNT1_LABEL=帳戶 1
ACCOUNT2_LABEL=帳戶 2

# 帳戶 1（舊變數名仍相容）
BINANCE_TESTNET_API_KEY=your_account1_testnet_key
BINANCE_TESTNET_API_SECRET=your_account1_testnet_secret
BINANCE_API_KEY=your_account1_live_key
BINANCE_API_SECRET=your_account1_live_secret

# 帳戶 2
BINANCE_ACCOUNT2_TESTNET_API_KEY=your_account2_testnet_key
BINANCE_ACCOUNT2_TESTNET_API_SECRET=your_account2_testnet_secret
BINANCE_ACCOUNT2_LIVE_API_KEY=your_account2_live_key
BINANCE_ACCOUNT2_LIVE_API_SECRET=your_account2_live_secret

# 可選：各帳戶資金（未設則用 LIVE_TOTAL_CAPITAL）
# ACCOUNT1_CAPITAL=1000
# ACCOUNT2_CAPITAL=5000

# 自動交易輪詢的 profile（單進程依序掃描）
# RUNNER_PROFILES=account1:paper,account1:testnet,account2:testnet
# RUNNER_PROFILES=all

# ── 下單模式說明 ───────────────────────────────────────────────
# paper   → 本地模擬 data/orders/{帳戶}_paper.json
# testnet → https://testnet.binancefuture.com
# live    → 主網實盤

# 啟動 24/7 多帳戶自動交易：
#   python live_runner.py --verify-only --profiles all
#   ./start_live_trader.sh --verify
#   ./start_live_trader.sh --bg                    # 多帳戶 testnet+paper
#   ./start_live_trader.sh --live --bg             # 含主網（需確認）

# 可選：Telegram 訊號通知
# TG_TOKEN=
# TG_CHAT_ID=

# 可選：自動交易資金參數（預設帳戶共用）
# LIVE_TOTAL_CAPITAL=1000
# LIVE_POSITION_PCT=1
